# GrowthOS AI Agent Configuration - Example
# Duplicate this file as `.env.local` and fill in your API keys.

# OpenAI API 配置 (默认)
OPENAI_API_KEY="your_openai_key_here"
OPENAI_API_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# DeepSeek API 配置 (优先备选，设置后后端会自动优先使用 DeepSeek)
DEEPSEEK_API_KEY="your_deepseek_key_here"
DEEPSEEK_API_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"

# (可选) Supabase 云端同步配置，用于同步 Local-first 本地数据与云端数据库
# NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# 站点入口密码（防止 AI 服务被他人滥用）
# 设置后访问网站需先输入密码验证，不设置或留空则跳过验证
SITE_PASSWORD="your_password_here"
